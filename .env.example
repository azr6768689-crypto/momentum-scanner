# =============================================================================
# Environment variables template
# =============================================================================
# HOW TO USE:
#   1. Copy this file to ".env" (without the .example extension)
#         cp .env.example .env
#   2. Fill in your real keys in .env
#   3. NEVER commit .env to git — it's already in .gitignore
#
# Production: use Polygon with a real API key (recommended).
# Demo mode is only for offline testing without a key.
# =============================================================================

# --- Application mode --------------------------------------------------------
# Options: "polygon" | "demo" | "tiingo" | "alpaca"
DATA_PROVIDER=polygon

# --- Tiingo (Phase 1) --------------------------------------------------------
# Get a free key at https://www.tiingo.com — free tier is enough to start.
# Upgrade to the paid tier (~$10/mo) for unlimited daily history.
TIINGO_API_KEY=

# --- Polygon.io (Phase 2 — intraday) -----------------------------------------
# Get a key at https://polygon.io. Stocks Starter (~$29/mo) needed for intraday.
POLYGON_API_KEY=

# --- Alpaca (alternative) ----------------------------------------------------
# https://alpaca.markets — paper trading is free.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Use "https://paper-api.alpaca.markets" for paper, NOT live, until Phase 7.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Application settings (optional overrides) -------------------------------
# Override the default config file location if you need to.
# CONFIG_PATH=config/settings.yaml

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Scan depth: simple | medium | full (see dashboard sidebar)
# SCAN_PROFILE=simple
# SCAN_WORKERS=16
# SCAN_TIMEOUT_SECONDS=   # optional override; defaults per profile
